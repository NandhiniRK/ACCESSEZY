# ─────────────────────────────────────────────────────────────
# Accessezy — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Flask secret key — change this to any long random string
SECRET_KEY=change-me-to-something-long-and-random

# Admin account email (this email gets admin access on login)
ADMIN_EMAIL=admin@accessezy.com

# ── Gmail SMTP for OTP emails ──────────────────────────────
# Use your Gmail address here
MAIL_USER=yourgmail@gmail.com

# Generate an App Password (NOT your real Gmail password):
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Search "App Passwords" at the top
#   4. Create one named "Accessezy"
#   5. Paste the 16-character password below (no spaces)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
